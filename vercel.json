{
  "version": 2,
  "name": "e-commerce-premium",
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "backend/public"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/app.js"
    },
    {
      "src": "^(.*)$",
      "dest": "/backend/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "MONGO_URI": "mongodb+srv://daniyalsaghir:daniyalmongodb@cluster0.nj9nrot.mongodb.net/ecom?appName=Cluster0"
  }
}