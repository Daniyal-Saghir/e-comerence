{
  "version": 2,
  "name": "e-commerce-premium",
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "backend/public"
      }
    }
  ],
  "rewrites": [
{
      "source": "/(.*)",
      "destination": "/backend/src/app.js"
    }

  ],
  "env": {
    "NODE_ENV": "production"
  }
}