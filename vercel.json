{
  "version": 2,
  "name": "e-commerce-premium",
  "builds": [
    {
      "src": "backend/src/app.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "backend/public"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/backend/src/app.js"
    },
    {
      "source": "/((?!api|health).*)",
      "destination": "/backend/public/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}